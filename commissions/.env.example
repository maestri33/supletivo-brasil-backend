# commissions — variáveis de ambiente (copie para .env e preencha)
ENV=development
LOG_LEVEL=INFO
PORT=8000

DATABASE_URL=postgresql+asyncpg://v7m:v7m@postgres:5432/v7m
DATABASE_SCHEMA=commissions

# ── Integrações ──
ASAAS_SERVICE_URL=http://asaas:8000
COORDINATOR_SERVICE_URL=http://coordinator:8000
PROMOTER_SERVICE_URL=http://promoter:8000
NOTIFY_SERVICE_URL=http://notify:8000

# ── Worker ──
COMMISSION_CRON_SCHEDULE=0 18 * * 5
COMMISSION_TIMEZONE=America/Sao_Paulo
