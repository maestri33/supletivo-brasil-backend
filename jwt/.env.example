# ============================================================================
# jwt — toda configuracao do servico em um unico lugar
# Copie pra .env e ajuste
# ============================================================================

# -- Servico --
SERVICE_NAME=jwt
ENV=prod
LOG_LEVEL=INFO
PORT=80

# -- JWT: algoritmo e expiracao --
JWT_ALGORITHM=RS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=1440
JWT_ISSUER=jwt
JWT_AUDIENCE=

# -- Chaves RSA (arquivos PEM) --
JWT_PRIVATE_KEY_FILE=private.pem
JWT_PUBLIC_KEY_FILE=public.pem
