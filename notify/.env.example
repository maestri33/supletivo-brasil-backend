# ============================================================================
# .env.example — copie pra .env e preencha
# ============================================================================
# Servico
SERVICE_NAME=notify
ENV=dev                       # dev | staging | prod
LOG_LEVEL=INFO
PORT=8000                     # porta interna do uvicorn (mapeada p/ 8157 externamente via compose)
PUBLIC_BASE_URL=http://notify:8000
DMZ_BASE_URL=http://notify:8000

# Banco — Postgres central v7m, schema notify
DATABASE_URL=postgresql+asyncpg://v7m:v7m@postgres:5432/v7m
DATABASE_SCHEMA=notify

# Redis (cache + pub/sub leve) — opcional
# REDIS_URL=redis://redis:6379/0

# RabbitMQ (mensageria entre microservices) — opcional
# AMQP_URL=amqp://guest:guest@rabbit:5672/

# Email (SMTP direto STARTTLS:587 + API admin Mailcow opcional)
# Envio: SMTP STARTTLS na porta 587 com app-password
# Admin: API REST para gerenciar mailboxes e app-passwords
MAILCOW_SMTP_HOST=mail.v7m.org
MAILCOW_SMTP_PORT=587
MAILCOW_SMTP_USER=contato@supletivo.net.br
MAILCOW_SMTP_PASS=                  # app-password (Mailcow UI > Mailboxes > app-passwords)
MAILCOW_FROM_EMAIL=contato@supletivo.net.br
MAILCOW_FROM_NAME=Supletivo
MAILCOW_TIMEOUT_S=30
MAILCOW_API_URL=https://mail.v7m.org
MAILCOW_API_KEY=                    # API key da Mailcow (admin UI > Access > API)

# WhatsApp API (Evolution GO / whatsmeow)
WHATSAPP_API_BASE_URL=http://whats-api:8080
WHATSAPP_GLOBAL_API_KEY=troque-isto
WHATSAPP_INSTANCE_NAME=default

# AI Service (texto, imagem, TTS, JSON estruturado)
AI_BASE_URL=http://ai:8000

# ElevenLabs TTS (text-to-speech)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_v3
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Gemini (geracao de imagens)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_VISION_MODEL=gemini-3-flash-preview
