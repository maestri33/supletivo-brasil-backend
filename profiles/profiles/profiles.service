[Unit]
Description=Profiles Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/profiles
EnvironmentFile=/root/profiles/.env
ExecStart=/root/profiles/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 80 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
