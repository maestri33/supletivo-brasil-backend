# Profiles service — exemplo de configuração.
# Copie para .env e preencha os valores reais (NÃO commitar .env).

# Core
ENV=dev
LOG_LEVEL=INFO
PORT=8000

# Banco (Postgres central da stack) — OBRIGATÓRIO, sem default no código.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_SCHEMA=profiles

# CORS / integrações
CORS_ORIGINS=["*"]
INTEGRATIONS={}

# CPFHub.io — server-side only. Deixe vazio para desabilitar o enriquecimento.
# https://cpfhub.io/ (rotacione a chave se for vazada).
CPFHUB_API_KEY=
CPFHUB_BASE_URL=https://api.cpfhub.io
CPFHUB_TIMEOUT_SECONDS=5.0
