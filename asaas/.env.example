# Database — Postgres central v7m, schema asaas
ASAAS_APP_DB_URL=postgresql+asyncpg://v7m:v7m@postgres:5432/v7m

# Asaas API
# Production: https://api.asaas.com (default)
# Sandbox:    https://sandbox.asaas.com
ASAAS_BASE_URL=https://api.asaas.com

# Aceitar chaves $aact_hmlg_* (sandbox/homologação) além de $aact_prod_*
# Default: false (production-only — seguro por padrão)
ASAAS_ALLOW_SANDBOX=false

# Charges: dias até vencimento padrão quando due_date não é informado
ASAAS_APP_CHARGE_DEFAULT_DUE_DAYS=3
