# ============================================================================
# Servico AI — variaveis de ambiente
# ============================================================================
# Copie para .env e preencha as chaves de API obrigatorias.
# Todos os valores abaixo sao os defaults — so mexa se precisar trocar.
# ============================================================================

# --- Identificacao do servico ---

SERVICE_NAME=ai
# ENV: dev | staging | prod — afeta logs e comportamento
ENV=dev
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# PORT: porta HTTP do servico (sempre 80, Caddy faz proxy pra ca)
PORT=80
# PUBLIC_BASE_URL: dominio publico usado pra montar URLs de midia (/media/*)
# O trafego publico chega via Caddy (ai.m33.live) → NAT → este LXC:80
# So /media/* e exposto publicamente; os endpoints da API sao internos
PUBLIC_BASE_URL=https://ai.m33.live


# --- DeepSeek (texto + JSON) ---
# API OpenAI-compatible. Cache KV ativado por padrao (gratuito).
# Unico que ainda usa REST/httpx direto (os outros tem SDK oficial).

# Obrigatorio — sem isso o servico nao gera texto nem JSON
DEEPSEEK_API_KEY=

# Base URL da API (nao trocar a menos que a DeepSeek mude)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Modelo padrao: deepseek-v4-pro (mais capaz, texto + JSON)
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-pro

# Temperatura padrao: 0.0=deterministico, 2.0=max criatividade
# 0.3 = bom equilibrio pra JSON/consistencia (sobrescrito por request)
DEEPSEEK_DEFAULT_TEMPERATURE=0.3

# Limite de tokens na resposta. 0 = nao envia (API decide, ate 1M no v4).
# Use um valor (ex: 4096) para limitar respostas ou evitar truncamento em JSON mode.
# Sobrescrito por request (parametro max_tokens)
DEEPSEEK_MAX_TOKENS=0


# --- ElevenLabs (text-to-speech) ---
# SDK oficial: AsyncElevenLabs + VoiceSettings.
# Nao depende de httpx — o SDK gerencia o proprio HTTP.

# Obrigatorio — sem isso o servico nao gera audio
ELEVENLABS_API_KEY=

# Voz padrao: George — voz masculina narrativa em ingles
# Funciona bem com portugues via language_code
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Modelo: eleven_v3 (multilingual, mais expressivo)
# Alternativas: eleven_multilingual_v2, eleven_flash_v2_5 (mais rapido)
ELEVENLABS_MODEL_ID=eleven_v3

# Formato de saida do audio
# mp3_44100_128 = bom equilibrio qualidade/tamanho
# mp3_44100_192 = qualidade maior, arquivo maior
# opus_48000_128 = codec moderno, melhor compressao
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Voice settings — todos sobrescritos por request
# stability: 0.0=mais variacao emocional, 1.0=mais estavel/monotono
ELEVENLABS_STABILITY=0.5
# similarity_boost: 0.0=menos fiel ao sample, 1.0=mais fiel (pode amplificar artefatos)
ELEVENLABS_SIMILARITY_BOOST=0.75
# speed: 0.25=muito lento, 1.0=normal, 4.0=muito rapido
ELEVENLABS_SPEED=1.0
# style: 0.0=desligado, 1.0=exagero maximo de expressao (requer v2+)
ELEVENLABS_STYLE=0.0
# speaker_boost: pos-processamento que melhora clareza e presenca
ELEVENLABS_SPEAKER_BOOST=true


# --- Gemini (imagem + visao) ---
# SDK oficial: google-genai (client.aio.models.generate_content).
# Usa httpx apenas pra download de imagens de referencia.

# Obrigatorio — sem isso o servico nao gera imagem nem descreve
GEMINI_API_KEY=

# Modelo de geracao de imagem
# gemini-3.1-flash-image-preview: mais rapido, suporta image_size e aspect_ratio
# Alternativa: gemini-3-pro-image-preview (mais qualidade, mais lento)
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Modelo de visao (describe imagens)
# gemini-3-flash-preview: rapido, bom para descricao
GEMINI_VISION_MODEL=gemini-3-flash-preview
