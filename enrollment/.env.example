# enrollment — variáveis de ambiente (padrão v7m, ver CONVENTION.md)
ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://v7m:v7m@postgres:5432/v7m
DATABASE_SCHEMA=enrollment

# URLs internas dos serviços que o enrollment consome (CONVENTION §7).
# Defaults batem com os service names do docker-compose; sobrescreva em prod.
AI_BASE_URL=http://ai:8000
NOTIFY_BASE_URL=http://notify:8000
DOCUMENTS_BASE_URL=http://documents:8000
ADDRESSES_BASE_URL=http://address:8000
PROFILES_BASE_URL=http://profiles:8000
ROLES_BASE_URL=http://roles:8000
JWT_BASE_URL=http://jwt:8000

HTTP_TIMEOUT=10
