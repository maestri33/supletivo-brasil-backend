[Unit]
Description=InfinitePay Outbound Webhook Worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=infinitepay
Group=infinitepay
WorkingDirectory=/opt/infinitepay
EnvironmentFile=-/etc/infinitepay/env
ExecStart=/opt/infinitepay/.venv/bin/ipay worker
Restart=on-failure
RestartSec=3
StateDirectory=infinitepay
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ReadWritePaths=/var/lib/infinitepay

[Install]
WantedBy=multi-user.target
