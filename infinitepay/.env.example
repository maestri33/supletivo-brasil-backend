# Database — Postgres central v7m, schema infinitepay
DATABASE_URL=postgresql+asyncpg://v7m:v7m@postgres:5432/v7m
DATABASE_SCHEMA=infinitepay

# InfinitePay API externa
INFINITEPAY_BASE_URL=https://api.checkout.infinitepay.io
HTTP_TIMEOUT=15
WORKER_POLL_SECONDS=5
RUN_INLINE_WORKER=true

# Fernet key p/ cifrar o external_id no webhook_url (rota publica).
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_ENCRYPTION_KEY=

# Config da loja (defaults de checkout) — antes na tabela `config`, agora 100% .env
INFINITEPAY_HANDLE=
INFINITEPAY_PRICE=
INFINITEPAY_QUANTITY=1
INFINITEPAY_DESCRIPTION=
INFINITEPAY_REDIRECT_URL=
INFINITEPAY_BACKEND_WEBHOOK=
INFINITEPAY_PUBLIC_API_URL=

# Integracao com o app `ai` central (mensagem de recibo + triagem de fraude)
AI_BASE_URL=http://ai:8000
AI_FEATURES_ENABLED=false
AI_MODEL=deepseek-v4-flash
AI_PRO_MODEL=deepseek-v4-pro
