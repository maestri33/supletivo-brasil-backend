# Database — Postgres central v7m, schema infinitepay
DATABASE_URL=postgresql+asyncpg://v7m:v7m@postgres:5432/v7m
DATABASE_SCHEMA=infinitepay

# InfinitePay API externa
INFINITEPAY_BASE_URL=https://api.checkout.infinitepay.io
HTTP_TIMEOUT=15
WORKER_POLL_SECONDS=5
RUN_INLINE_WORKER=true

# Fernet key p/ cifrar o external_id no webhook_url (rota publica).
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_ENCRYPTION_KEY=

# Seguranca de webhook — HMAC secret (assinatura x-infinitepay-signature).
# A chave secreta e configurada no painel InfinitePay e replicada aqui.
# Em dev/staging: omissao = bypass (webhook aceito sem assinatura).
# Em producao: OBRIGATORIO configurar — sem secret, readiness retorna NOT ok.
INFINITEPAY_WEBHOOK_SECRET=

# Seguranca de webhook — IP allow-list (CIDRs separados por virgula).
# Em dev/staging: omissao = aceitar todos (0.0.0.0/0).
# Em producao: OBRIGATORIO configurar — sem CIDRs todos os webhooks sao rejeitados (fail-closed).
# Exemplo: INFINITEPAY_WEBHOOK_ALLOWED_CIDRS=18.231.0.0/16,52.67.0.0/24
# Para desabilitar completamente (dev): defina como vazio INFINITEPAY_WEBHOOK_ALLOWED_CIDRS=
INFINITEPAY_WEBHOOK_ALLOWED_CIDRS=

# Config da loja (defaults de checkout) — antes na tabela `config`, agora 100% .env
INFINITEPAY_HANDLE=v7m
INFINITEPAY_PRICE=100 #preço é em centavos, ou seja, para R$1,00 é = 100
INFINITEPAY_QUANTITY=1
INFINITEPAY_DESCRIPTION="Material Didático - Curso Supletivo"
INFINITEPAY_REDIRECT_URL=https://lead.supletivo.net/
INFINITEPAY_BACKEND_WEBHOOK=
INFINITEPAY_PUBLIC_API_URL=https://api.supletivo.net/


