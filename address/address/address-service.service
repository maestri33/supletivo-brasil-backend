[Unit]
Description=Address Service - Generic address microservice
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/address
EnvironmentFile=/root/address/.env
ExecStartPre=/root/address/.venv/bin/alembic upgrade head
ExecStart=/root/address/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --log-level info
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
