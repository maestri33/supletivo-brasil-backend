# Addresses service — exemplo de configuração.
# Copie para .env e preencha (NÃO commitar .env).

ENV=dev
LOG_LEVEL=INFO
PORT=8000

DATABASE_URL=postgresql+asyncpg://v7m:v7m@postgres:5432/v7m
DATABASE_SCHEMA=addresses

CORS_ORIGINS=*

# ViaCEP — lookup de CEP (feature do LOCAL, implementada).
VIACEP_BASE_URL=https://viacep.com.br
VIACEP_TIMEOUT_SECONDS=5.0

# Webhook — disparado em create/update/delete de Address (best-effort).
# Deixe vazio para desativar.
WEBHOOK_URL=http://10.10.10.129
WEBHOOK_TIMEOUT_SECONDS=5.0

# Upload de comprovante (proof) das entity_addresses.
UPLOAD_DIR=uploads
