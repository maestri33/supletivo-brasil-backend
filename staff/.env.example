# ── Identidade ──────────────────────────────────────────────────
SERVICE_NAME=staff
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Banco ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://v7m:v7m@localhost:5432/v7m
DATABASE_SCHEMA=staff

# ── Auth (JWT via serviço auth/jwt) ────────────────────────────
JWT_BASE_URL=http://jwt:8000

# Roles permitidas para endpoints autenticados do staff
STAFF_ROLES=["admin","staff"]

# ── HTTP ────────────────────────────────────────────────────────
HTTP_TIMEOUT=10
CORS_ORIGINS=["*"]
