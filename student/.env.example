# ── Banco ─────────────────────────────────────────────────────
# Postgres central, schema `student`. Obrigatorio.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_SCHEMA=student

# ── JWT (JWKS em /.well-known/jwks.json) ─────────────────────
JWT_BASE_URL=http://jwt:8000

# ── Integracoes internas (CONVENTION §7) ─────────────────────
AI_BASE_URL=http://ai:80
DOCUMENTS_BASE_URL=http://documents:8000
NOTIFY_BASE_URL=http://notify:8000
COMMISSIONS_BASE_URL=http://commissions:8000
ROLES_BASE_URL=http://roles:8000
PROFILES_BASE_URL=http://profiles:8000

# Timeout em segundos para qualquer client httpx.
HTTP_TIMEOUT=10.0

# Valor da comissao do coordenador na formatura (centavos).
COORDINATOR_COMMISSION_CENTS=50

# ── CORS — lista JSON de origens permitidas (opcional) ───────
# CORS_ORIGINS=["https://app.example.com"]
