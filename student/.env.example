# Banco — Postgres central, schema `student`. Obrigatorio (sem default no codigo).
STUDENT_APP_DB_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# JWT — base URL do servico jwt (JWKS em /.well-known/jwks.json). Obrigatorio.
JWT_BASE_URL=http://jwt:8000

# CORS — lista JSON de origens permitidas (opcional).
# CORS_ORIGINS=["https://app.example.com"]
