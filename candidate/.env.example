# Banco — Postgres central, schema proprio `candidate` (obrigatorio, sem default)
CANDIDATE_APP_DB_URL=postgresql+asyncpg://user:pass@postgres:5432/v7m
DATABASE_SCHEMA=candidate

# Servicos internos (HTTP)
AUTH_BASE_URL=http://auth:8000
JWT_BASE_URL=http://jwt:8000
NOTIFY_BASE_URL=http://notify:8000
PROFILES_BASE_URL=http://profiles:8000
ADDRESSES_BASE_URL=http://addresses:8000
ROLES_BASE_URL=http://roles:8000
ASAAS_BASE_URL=http://asaas:8000
DOCUMENTS_BASE_URL=http://documents:8000
AI_BASE_URL=http://ai:8000

# Negocio — hub padrao quando o cadastro nao informa um hub
HUB_DEFAULT=00000000-0000-0000-0000-000000000000

# HTTP
HTTP_TIMEOUT=10

# Ambiente
SERVICE_NAME=candidate
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
