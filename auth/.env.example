# auth — variáveis de ambiente (copie para .env e preencha)
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_VERSION=0.1.0
PORT=8000

DATABASE_URL=postgresql+asyncpg://v7m:v7m@postgres:5432/v7m
DB_SCHEMA=auth
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=["*"]

# ── Integrações (service URLs) ──
ADDRESS_SERVICE_URL=http://address:8000
DOCUMENTS_SERVICE_URL=http://documents:8000
JWT_SERVICE_URL=http://jwt:8000
NOTIFY_SERVICE_URL=http://notify:8000
OTP_SERVICE_URL=http://otp:8000
PROFILES_SERVICE_URL=http://profiles:8000
ROLES_SERVICE_URL=http://roles:8000
