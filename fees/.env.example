# fees — variaveis de ambiente (padrao v7m, ver ../CONVENTION.md)
ENV=development
LOG_LEVEL=INFO

# Banco (OBRIGATORIO — sem default com credenciais; injete o valor real)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@postgres:5432/v7m
DATABASE_SCHEMA=fees

# Integracoes internas (nomes de servico na network do docker-compose)
ASAAS_BASE_URL=http://asaas:8000
NOTIFY_BASE_URL=http://notify:8000
JWT_BASE_URL=http://jwt:8000
HTTP_TIMEOUT=10

# Autorizacao: role exigida nos endpoints autenticados
COORDINATOR_ROLE=coordinator

# Negocio
FEE_DESCRIPTION_DEFAULT=Taxa de matricula
