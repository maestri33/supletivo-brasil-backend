# =============================================================================
# .env.example — Variáveis de ambiente para desenvolvimento local
# =============================================================================
# Copie para .env e ajuste conforme necessário.
# Este arquivo serve como referência; cada serviço tem seu próprio .env.example.
# =============================================================================

# ── Ambiente ──
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# ── Database ──
DATABASE_URL=postgresql+asyncpg://supletivo:supletivo_dev@localhost:5432/supletivo
POSTGRES_DB=supletivo
POSTGRES_USER=supletivo
POSTGRES_PASSWORD=supletivo_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Service URLs (desenvolvimento local) ──
ADDRESS_SERVICE_URL=http://localhost:8001
AI_SERVICE_URL=http://localhost:8002
ASAAS_SERVICE_URL=http://localhost:8003
AUTH_SERVICE_URL=http://localhost:8004
CANDIDATE_SERVICE_URL=http://localhost:8005
ENROLLMENT_SERVICE_URL=http://localhost:8009
FEES_SERVICE_URL=http://localhost:8010
HUB_SERVICE_URL=http://localhost:8011
INFINITEPAY_SERVICE_URL=http://localhost:8012
JWT_SERVICE_URL=http://localhost:8013
LEAD_SERVICE_URL=http://localhost:8014
NOTIFY_SERVICE_URL=http://localhost:8015
OTP_SERVICE_URL=http://localhost:8016
PROFILES_SERVICE_URL=http://localhost:8017
PROMOTER_SERVICE_URL=http://localhost:8018
ROLES_SERVICE_URL=http://localhost:8019
STAFF_SERVICE_URL=http://localhost:8020
STUDENT_SERVICE_URL=http://localhost:8021
TRAINING_SERVICE_URL=http://localhost:8022
DOCUMENTS_SERVICE_URL=http://localhost:8008

# ── CORS ──
CORS_ORIGINS=*

# ── Segurança ──
JWT_SECRET=dev-secret-change-in-production
API_KEY=dev-key-change-in-production

# ── Observabilidade ──
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
