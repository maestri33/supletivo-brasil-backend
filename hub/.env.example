# hub — variaveis de ambiente (padrao v7m, ver CONVENTION.md)
ENV=dev
LOG_LEVEL=INFO
# Obrigatorio: URL async do Postgres central (sem default no codigo, §Fase 1).
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@postgres:5432/DBNAME
DATABASE_SCHEMA=hub

# ── Auth (JWT via servico auth/jwt) ────────────────────────────
JWT_BASE_URL=http://jwt:8000
# Roles permitidas para endpoints autenticados do hub
STAFF_ROLES=["admin","staff"]

# ── HTTP ────────────────────────────────────────────────────────
HTTP_TIMEOUT=10
CORS_ORIGINS=["*"]
