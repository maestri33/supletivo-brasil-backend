# Banco — Postgres central, schema proprio `promoter` (obrigatorio, sem default)
PROMOTER_APP_DB_URL=postgresql+asyncpg://user:pass@postgres:5432/v7m
DATABASE_SCHEMA=promoter

# Servicos internos (HTTP)
AUTH_BASE_URL=http://auth:8000
JWT_BASE_URL=http://jwt:8000
NOTIFY_BASE_URL=http://notify:8000
PROFILES_BASE_URL=http://profiles:8000
ROLES_BASE_URL=http://roles:8000
LEAD_BASE_URL=http://lead:8000
COMMISSIONS_BASE_URL=http://commissions:8000

# Negocio
HUB_DEFAULT=00000000-0000-0000-0000-000000000000
# Base da landing de captacao; o promoter divulga <base>/ref=<external_id>
LANDING_BASE_URL=https://captacao.exemplo.com

# HTTP
HTTP_TIMEOUT=10

# Ambiente
SERVICE_NAME=promoter
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
