# roles — variáveis de ambiente (copie para .env e preencha)
SERVICE_NAME=roles
DATABASE_URL=postgresql+asyncpg://v7m:v7m@postgres:5432/v7m
DATABASE_SCHEMA=roles
HOST=0.0.0.0
PORT=8000

# Catálogo de papéis válidos. JSON-array.
VALID_ROLES=["lead","candidate","enrollment","promoter","student","veteran","coordinator","staff","admin"]

# Regras de transição. JSON-array. Campos: from_role (str|null), to_role (str),
# mode ("add"|"replace"), requires_role (str|null), forbids_role (str|null), blocking (bool).
# Se não definir, o default no config.py é usado. Defina aqui para override.
# ROLE_RULES=[{"from_role":null,"to_role":"lead","mode":"add"},{"from_role":"lead","to_role":"enrollment","mode":"replace"},{"from_role":"enrollment","to_role":"student","mode":"replace"},{"from_role":null,"to_role":"veteran","mode":"add","requires_role":"student"},{"from_role":null,"to_role":"candidate","mode":"add"},{"from_role":"candidate","to_role":"promoter","mode":"replace"},{"from_role":null,"to_role":"coordinator","mode":"add","requires_role":"promoter"}]
