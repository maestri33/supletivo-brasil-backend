# Banco — Postgres central, schema proprio `training` (obrigatorio, sem default)
TRAINING_APP_DB_URL=postgresql+asyncpg://user:pass@postgres:5432/v7m
DATABASE_SCHEMA=training

# Midia (video/foto das materias) armazenada no proprio training — volume local
MEDIA_DIR=/app/media
MAX_UPLOAD_MB=200

# Ambiente / observabilidade
SERVICE_NAME=training
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
