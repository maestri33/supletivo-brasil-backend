{
  "$comment": "Configuração do Claude Code exclusivo deste serviço. Modelo: DeepSeek v4 Pro. Obtenha sua API Key em https://platform.deepseek.com/ e configure .env",
  "model": "deepseek-v4-pro",
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "${ANTHROPIC_AUTH_TOKEN}",
    "ANTHROPIC_MODEL": "deepseek-v4-pro",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek-v4-pro",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-v4-pro",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-flash",
    "ANTHROPIC_SMALL_FAST_MODEL": "deepseek-v4-flash",
    "CLAUDE_CODE_SUBAGENT_MODEL": "deepseek-v4-flash",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "permissions": {
    "allow": [
      "Bash(uv *)",
      "Bash(make *)",
      "Bash(pytest *)",
      "Bash(aerich *)",
      "Bash(curl http://localhost:80/*)",
      "Bash(curl http://127.0.0.1:80/*)",
      "Read(./**)",
      "Edit(./app/**)",
      "Edit(./tests/**)",
      "Edit(./.claude/memory/**)",
      "Write(./app/**)",
      "Write(./tests/**)",
      "Write(./.claude/memory/**)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Edit(./pyproject.toml)",
      "Edit(./.env)",
      "Edit(./.claude/CLAUDE.md)"
    ]
  }
}

