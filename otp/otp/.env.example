# ============================================================================
# .env.example — copie pra .env e ajuste
# ============================================================================
# Servico
SERVICE_NAME=otp
ENV=dev
LOG_LEVEL=INFO
PORT=8000

# Banco — cluster Postgres central, schema otp
DATABASE_URL=postgresql+asyncpg://v7m:v7m@postgres:5432/v7m
DATABASE_SCHEMA=otp

# Servico externo notify
NOTIFY_BASE_URL=http://notify:8000
WEBHOOK_BASE_URL=http://otp:8000

# OTP — regras de negocio
OTP_FOOTER=Equipe OTP
OTP_TTL_S=300
OTP_NUM_DIGITS=6
OTP_MAX_ATTEMPTS=3
OTP_ACTIVE=true

# Rate limit (por external_id) — adicionado em 2026-05-15
OTP_RATELIMIT_WINDOW_S=30
OTP_RATELIMIT_HOURLY_MAX=5

# Cleanup automatico de logs antigos — adicionado em 2026-05-15
OTP_CLEANUP_INTERVAL_S=3600
OTP_CLEANUP_RETENTION_DAYS=30
